# Copy to .env, fill in, then:  set -a; source .env; set +a
# NEVER commit the real .env. chmod 600 it.

# --- vCenter target ---------------------------------------------------------
# Day 2-3: vcsim simulator
VCENTER_HOST=127.0.0.1
VCENTER_PORT=8989
VCENTER_USER=user
VCENTER_PASSWORD=pass
VCENTER_INSECURE=true

# Day 4+: real vCenter (read-only service account — see runbook §Day 4)
#VCENTER_HOST=vcenter.example.local
#VCENTER_PORT=443
#VCENTER_USER=svc-boip-ro@vsphere.local
#VCENTER_PASSWORD=********
#VCENTER_INSECURE=true   # only if self-signed certs; fix properly later

# --- boip tools -------------------------------------------------------------
BOIP_TOOLS_DIR=/opt/boip

# --- LLM for HolmesGPT ------------------------------------------------------
# Week 1: use a strong API model to test the CEILING of what's possible.
# Sovereign/local models are a Week 8 experiment, after you know the ceiling.
ANTHROPIC_API_KEY=sk-ant-...
# or: OPENAI_API_KEY=...
