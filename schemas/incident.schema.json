{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Incident",
  "type": "object",
  "required": [
    "id",
    "title",
    "state",
    "severity",
    "started_at",
    "affected_assets"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "affected_assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_bundle_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "confirmed_root_cause": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
