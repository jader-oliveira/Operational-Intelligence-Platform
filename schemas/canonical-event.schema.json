{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "source",
    "event_time",
    "ingest_time",
    "schema_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "ingest_time": {
      "type": "string",
      "format": "date-time"
    },
    "asset_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "classification": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
